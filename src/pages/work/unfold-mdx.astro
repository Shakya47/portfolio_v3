---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.tsx';
import UnfoldLiveDemo from '../../components/UnfoldLiveDemo.tsx';
import { ArrowLeft, Github, ExternalLink, ShieldCheck, Zap, Layers, FileText } from 'lucide-react';
---

<Layout 
  title="unfold-mdx | Progressive-depth Prose & Code Explanations" 
  description="Deep dive into unfold-mdx, a React component library to build progressive-depth prose & code explanations with sentence-level prose diffing and line-level code diffs."
>
  <!-- Nav -->
  <nav class="sticky top-0 z-40 bg-white dark:bg-[#0E0E10] border-b-3 border-current px-4 md:px-8 py-4 flex justify-between items-center" aria-label="Main Navigation">
    <a href="/" class="brutal-border-sm brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border px-3 py-1.5 font-mono text-xs font-black uppercase border-current flex items-center gap-1.5" aria-label="Back to landing page">
      <ArrowLeft className="w-3.5 h-3.5 stroke-[2.5]" />
      <span>BACK TO HOME</span>
    </a>
    <div class="flex items-center gap-3">
      <ThemeToggle client:load />
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 py-8 md:py-16 flex flex-col gap-12 font-mono">
    <!-- Header -->
    <header class="flex flex-col gap-4 border-b-3 border-current pb-8">
      <div class="flex flex-wrap gap-2">
        <span class="brutal-border-sm px-2.5 py-0.5 bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300 border-blue-400 text-[10px] font-extrabold uppercase tracking-wide">
          OSS
        </span>
        <span class="brutal-border-sm px-2.5 py-0.5 bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300 border-red-400 text-[10px] font-extrabold uppercase tracking-wide">
          NPM
        </span>
        <span class="brutal-border-sm px-2.5 py-0.5 bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300 border-emerald-400 text-[10px] font-extrabold uppercase tracking-wide">
          React Binding
        </span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-none">
        unfold-mdx
      </h1>
      <p class="text-base font-bold text-zinc-500 dark:text-zinc-400 leading-relaxed max-w-2xl">
        Progressive-depth prose & code explanations for React and MDX. Diffs consecutive snapshots at sentence & line/token levels with zero accordions or scroll jumps.
      </p>
    </header>

    <!-- Project Overview -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      <div class="md:col-span-2 flex flex-col gap-6">
        <h2 class="text-xl font-black border-b-2 border-current pb-2 uppercase text-[#2563EB]">The Origin & Problem</h2>
        <p class="text-xs leading-relaxed text-zinc-600 dark:text-zinc-300">
          Technical tutorials and documentation platforms face a constant compromise: how to address both beginners and advanced developers in the same explanation. Traditional tools solve this with accordion panels, tab switches, or separate pages, all of which break focus, cause scroll jumps, and isolate content.
        </p>
        <p class="text-xs leading-relaxed text-zinc-600 dark:text-zinc-300">
          <strong>unfold-mdx</strong> is a headless React framework that enables inline progressive disclosure of text and code. By arranging multiple "depth levels" within a single container, the reader can drill down into a concepts details step-by-step.
        </p>
        <p class="text-xs leading-relaxed text-zinc-600 dark:text-zinc-300">
          Rather than simple hiding or revealing, the engine dynamically performs <strong>sentence-level prose diffing</strong> and <strong>line-and-token-level code diffing</strong> using custom tokenization algorithms. Added, updated, or deleted segments are subtly highlighted with customizable styling, creating an intuitive flow of modifications.
        </p>
      </div>

      <div class="brutal-border bg-zinc-50 dark:bg-zinc-900 p-6 border-current flex flex-col gap-4">
        <h3 class="font-black text-xs uppercase border-b border-dashed border-current pb-2">Specs & Info</h3>
        <ul class="flex flex-col gap-3 text-[10px]">
          <li class="flex justify-between border-b border-zinc-200 dark:border-zinc-800 pb-1">
            <span class="text-zinc-400">Published package:</span>
            <span class="font-bold">@unfold-mdx/react</span>
          </li>
          <li class="flex justify-between border-b border-zinc-200 dark:border-zinc-800 pb-1">
            <span class="text-zinc-400">NPM Keywords:</span>
            <span class="font-bold">mdx, headless, diff</span>
          </li>
          <li class="flex justify-between border-b border-zinc-200 dark:border-zinc-800 pb-1">
            <span class="text-zinc-400">Main Tech:</span>
            <span class="font-bold">React, Shiki, DiffMatchPatch</span>
          </li>
          <li class="flex justify-between pb-1">
            <span class="text-zinc-400">License:</span>
            <span class="font-bold">MIT</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Live Demo Island -->
    <section class="brutal-border border-current p-6 brutal-shadow bg-white dark:bg-zinc-950 flex flex-col gap-4">
      <div class="border-b border-dashed border-current pb-2">
        <h2 class="text-lg font-black uppercase text-[#2563EB]">Live Interactive Demonstration</h2>
        <p class="text-[10px] text-zinc-400">Step through the progressive disclosure explanation of a react side-effect below</p>
      </div>
      <UnfoldLiveDemo client:load />
    </section>

    <!-- Technical Architecture -->
    <section id="technical-deep-dive" class="flex flex-col gap-6">
      <h2 class="text-xl font-black border-b-2 border-current pb-2 uppercase text-[#2563EB]">Technical Deep Dive</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Sentence-level Prose Diffing -->
        <div class="brutal-border bg-white dark:bg-zinc-900 border-current p-5 brutal-shadow-sm flex flex-col gap-3">
          <div class="flex items-center gap-2 text-[#2563EB]">
            <FileText className="w-5 h-5" />
            <h3 class="font-black text-xs uppercase">Sentence Prose Diffing</h3>
          </div>
          <p class="text-[11px] leading-relaxed text-zinc-500">
            Instead of diffing by character or word, which creates distracting fragments, `unfold-mdx` tokenizes prose by sentence. It runs Google's `diff-match-patch` across these sentence arrays, pinpointing exactly where items are added or modified, and mapping them to visual states with data-attributes.
          </p>
        </div>

        <!-- Token-level Code Diffing -->
        <div class="brutal-border bg-white dark:bg-zinc-900 border-current p-5 brutal-shadow-sm flex flex-col gap-3">
          <div class="flex items-center gap-2 text-[#2563EB]">
            <Layers className="w-5 h-5" />
            <h3 class="font-black text-xs uppercase">Line & Token Code Diffing</h3>
          </div>
          <p class="text-[11px] leading-relaxed text-zinc-500">
            For code codeblocks, the library computes line-by-line additions and updates. If a line is modified, it runs a secondary character diff to generate token spans for added text inline. This avoids drawing full block insertions for single-character edits.
          </p>
        </div>

        <!-- Shiki Integration -->
        <div class="brutal-border bg-white dark:bg-zinc-900 border-current p-5 brutal-shadow-sm flex flex-col gap-3">
          <div class="flex items-center gap-2 text-[#2563EB]">
            <Zap className="w-5 h-5" />
            <h3 class="font-black text-xs uppercase">Asynchronous Shiki Coloring</h3>
          </div>
          <p class="text-[11px] leading-relaxed text-zinc-500">
            Syntax coloring uses Shiki's highlighter engine. Because Shiki is heavy and loads grammars asynchronously, the library falls back to uncolored raw diff markup instantly on hydration, then swap colors once loaded without layout jumps.
          </p>
        </div>

        <!-- Headless & SSR Fallbacks -->
        <div class="brutal-border bg-white dark:bg-zinc-900 border-current p-5 brutal-shadow-sm flex flex-col gap-3">
          <div class="flex items-center gap-2 text-[#2563EB]">
            <ShieldCheck className="w-5 h-5" />
            <h3 class="font-black text-xs uppercase">SSR & No-JS Graceful Fallback</h3>
          </div>
          <p class="text-[11px] leading-relaxed text-zinc-500">
            To satisfy SEO indexing requirements, all code snapshots and text levels are compiled into the server-rendered HTML payload. The deepest level is shown by default. Once client JS loads, active visibility switches over and hydrates into the interactive control deck.
          </p>
        </div>
      </div>
    </section>

    <!-- Usage Code Snippet -->
    <section class="flex flex-col gap-4">
      <h2 class="text-xl font-black border-b-2 border-current pb-2 uppercase text-[#2563EB]">Usage & Code Sample</h2>
      <div class="brutal-border border-current bg-zinc-50 dark:bg-zinc-950 p-6 brutal-shadow-sm text-[11px] leading-relaxed">
        <div class="flex justify-between items-center text-[10px] text-zinc-400 border-b border-zinc-200 dark:border-zinc-800 pb-2 mb-3">
          <span>MDX IMPLEMENTATION EXAMPLE</span>
          <span>explanation.mdx</span>
        </div>
        <pre class="overflow-x-auto text-[#2563EB] font-black">
{`import { Depth, DepthLevel, DepthCode } from "@unfold-mdx/react";
import "@unfold-mdx/react/theme.css";

<Depth show="both" orientation="horizontal" ratio={0.5} indicators={true}>
  <DepthLevel label="Basic">
    Fission splits a heavy atom into two lighter ones.
  </DepthLevel>
  <DepthCode lang="js">
  \`\`\`js
  const status = "splitting";
  \`\`\`
  </DepthCode>

  <DepthLevel label="Triggered">
    Fission splits a heavy atom into two lighter ones.
    The split is triggered by a neutron striking the nucleus.
  </DepthLevel>
  <DepthCode lang="js">
  \`\`\`js
  const status = "splitting";
  const trigger = "neutron";
  \`\`\`
  </DepthCode>
</Depth>`}</pre>
      </div>
    </section>

    <!-- GitHub and NPM Links footer CTAs -->
    <section class="flex flex-wrap gap-4 border-t-3 border-current pt-8 mb-8">
      <a 
        href="https://github.com/Shakya47/unfold-mdx" 
        target="_blank" 
        rel="noopener noreferrer"
        class="brutal-border brutal-shadow-sm brutal-btn-hover bg-[#2563EB] text-white px-6 py-3 font-black uppercase text-xs border-current flex items-center gap-2 focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-accent"
        aria-label="View unfold-mdx source code on GitHub"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
        Explore GitHub Source
      </a>
      <a 
        href="https://shakya47.github.io/unfold-mdx" 
        target="_blank" 
        rel="noopener noreferrer"
        class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border px-6 py-3 font-black uppercase text-xs border-current flex items-center gap-2 focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-accent"
        aria-label="Visit unfold-mdx live landing page"
      >
        <ExternalLink className="w-4 h-4" aria-hidden="true" />
        Visit Live Landing Page
      </a>
      <a 
        href="https://www.npmjs.com/package/@unfold-mdx/react" 
        target="_blank" 
        rel="noopener noreferrer"
        class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border px-6 py-3 font-black uppercase text-xs border-current flex items-center gap-2 focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-accent"
        aria-label="View @unfold-mdx/react package on npm registry"
      >
        <ExternalLink className="w-4 h-4" aria-hidden="true" />
        View npm Registry page
      </a>
    </section>

    <!-- Other Selected Work navigation links -->
    <section class="flex flex-col gap-4 border-t-3 border-current pt-8 mb-8" aria-label="Other case studies navigation">
      <h3 class="font-black text-xs uppercase">Other Selected Work Case Studies</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a 
          href="/work/pip-it-up" 
          class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border p-4 font-black uppercase text-xs border-current flex items-center justify-between"
        >
          <span>pip-it-up</span>
          <span>&gt;</span>
        </a>
        <a 
          href="/work/note-it-down" 
          class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border p-4 font-black uppercase text-xs border-current flex items-center justify-between"
        >
          <span>note-it-down Editor</span>
          <span>&gt;</span>
        </a>
        <a 
          href="/work/lender-price" 
          class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border p-4 font-black uppercase text-xs border-current flex items-center justify-between"
        >
          <span>Lender Price</span>
          <span>&gt;</span>
        </a>
        <a 
          href="/work/phox-health" 
          class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border p-4 font-black uppercase text-xs border-current flex items-center justify-between"
        >
          <span>Phox Health</span>
          <span>&gt;</span>
        </a>
        <a 
          href="/work/culturenow" 
          class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border p-4 font-black uppercase text-xs border-current flex items-center justify-between"
        >
          <span>CultureNow</span>
          <span>&gt;</span>
        </a>
        <a 
          href="/work/zero-knowledge-sync" 
          class="brutal-border brutal-shadow-sm brutal-btn-hover bg-white dark:bg-zinc-900 text-light-border dark:text-dark-border p-4 font-black uppercase text-xs border-current flex items-center justify-between"
        >
          <span>ZK Sync Layer</span>
          <span>&gt;</span>
        </a>
      </div>
    </section>
  </main>
</Layout>
